ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1635732928.9584219455718994140625;i:4;a:0:{}i:5;i:8961192;}i:249;a:6:{i:0;s:355:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:30:\"/alhuda/web/fee/fee-submission\";__id|i:1571;', 1571, 1, 'ebnvnp4f9550vb0qg020ak6fl2', 1636942528) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1635732928.9594490528106689453125;i:4;a:0:{}i:5;i:8966848;}i:250;a:6:{i:0;s:355:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:30:\"/alhuda/web/fee/fee-submission\";__id|i:1571;', 1571, 1, 'ebnvnp4f9550vb0qg020ak6fl2', 1636942528) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1635732928.9598829746246337890625;i:4;a:0:{}i:5;i:8967288;}}}";s:2:"db";s:115135:"a:1:{s:8:"messages";a:152:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1635732928 AND `id`='ebnvnp4f9550vb0qg020ak6fl2'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1635732928.11147403717041015625;i:4;a:0:{}i:5;i:4446040;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1635732928 AND `id`='ebnvnp4f9550vb0qg020ak6fl2'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1635732928.11170196533203125;i:4;a:0:{}i:5;i:4446976;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1635732928.1175239086151123046875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5221968;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i