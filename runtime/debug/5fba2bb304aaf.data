ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1606036403.137981891632080078125;i:4;a:0:{}i:5;i:3279416;}i:259;a:6:{i:0;s:396:"SELECT
