ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1664513488.8328011035919189453125;i:4;a:0:{}i:5;i:25348800;}i:3266;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'vgvmao8fef3gbpcjn549dq6333', 1665723088) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1664513488.8331120014190673828125;i:4;a:0:{}i:5;i:25419960;}i:3267;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'vgvmao8fef3gbpcjn549dq6333', 1665723088) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1664513488.8335449695587158203125;i:4;a:0:{}i:5;i:25420400;}}}";s:2:"db";s:1345317:"a:1:{s:8:"messages";a:2158:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1664513487 AND `id`='vgvmao8fef3gbpcjn549dq6333'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1664513487.5406830310821533203125;i:4;a:0:{}i:5;i:4445424;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1664513487 AND `id`='vgvmao8fef3gbpcjn549dq6333'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1664513487.54102802276611328125;i:4;a:0:{}i:5;i:4446328;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1664513487.5471670627593994140625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5221304;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::quer