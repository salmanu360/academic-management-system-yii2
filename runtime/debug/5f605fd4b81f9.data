FROM `information_schema`.`STATISTICS` AS `s`
WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1600151509.099822998046875;i:4;a:0:{}i:5;i:7435464;}i:91;a:6:{i:0;s:417:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:19:\"/alhuda/web/student\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'rb8jmtoepntc2dl3dft32p6mc6', 1601361108) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1600151509.1000831127166748046875;i:4;a:0:{}i:5;i:7441808;}i:92;a:6:{i:0;s:417:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:19:\"/alhuda/web/student\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'rb8jmtoepntc2dl3dft32p6mc6', 1601361108) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1600151509.673716068267822265625;i:4;a:0:{}i:5;i:7442248;}}}";s:2:"db";s:27778:"a:1:{s:8:"messages";a:48:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1600151508 AND `id`='rb8jmtoepntc2dl3dft32p6mc6'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1600151508.7464869022369384765625;i:4;a:0:{}i:5;i:4469184;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1600151508 AND `id`='rb8jmtoepntc2dl3dft32p6mc6'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1600151508.747068881988525390625;i:4;a:0:{}i:5;i:4470104;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1600151508.7512819766998291015625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"