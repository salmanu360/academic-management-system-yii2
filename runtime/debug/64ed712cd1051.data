i:0;s:1111:"SELECT `st`.`stu_id`, `st`.`is_active`, concat(u.first_name," ",u.last_name) student_name, `c`.`class_id`, `c`.`title`, `g`.`group_id`, `g`.`title`, `s`.`section_id`, `s`.`title`, `sm`.`remarks`, `sb`.`title` AS `subject`, sum(exam.total_marks) total_marks, sum(exam.passing_marks) passing_marks, round(sum(sm.marks_obtained),2) marks_obtained FROM `exam` INNER JOIN `exam_type` `et` ON et.id=exam.fk_exam_type INNER JOIN `ref_class` `c` ON c.class_id=exam.fk_class_id INNER JOIN `subjects` `sb` ON sb.id=exam.fk_subject_id LEFT JOIN `student_marks` `sm` ON sm.fk_exam_id=exam.id LEFT JOIN `student_info` `st` ON  st.stu_id=sm.fk_student_id LEFT JOIN `ref_group` `g` ON g.group_id=exam.fk_group_id LEFT JOIN `ref_section` `s` ON s.class_id=exam.fk_class_id INNER JOIN `user` `u` ON u.id=st.user_id WHERE (`exam`.`fk_branch_id`=1) AND (`c`.`class_id`='1') AND (`g`.`group_id` IS NULL) AND (`s`.`section_id`='15') AND (`st`.`stu_id`='3047') AND (`et`.`id`='400') AND (`st`.`is_active`=1) GROUP BY `st`.`stu_id`, `c`.`class_id`, `c`.`title`, `g`.`group_id`, `g`.`title`, `s`.`section_id`, `s`.`title`, `sb`.`title`";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1693282692.7164709568023681640625;i:4;a:1:{i:0;a:5:{s:4:"file";s:65:"/home/onnviiod/public_html/alhuda/controllers/ExamsController.php";s:4:"line";i:1889;s:8:"function";s:3:"all";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}}i:5;i:31289272;}i:3237;a:6:{i:0;s:42:"SELECT * FROM `exam_type` WHERE `id`='400'";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1693282692.718431949615478515625;i:4;a:1:{i:0;a:5:{s:4:"file";s:65:"/home/onnviiod/public_html/alhuda/controllers/ExamsController.php";s:4:"line";i:1890;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:31288296;}i:3240;a:6:{i:0;s:97:"Rendering view file: /home/onnviiod/public_html/alhuda/views/exams/_ajax/pdfs/student-dmc-pdf.php";i:1;i:8;i:2;s:25:"yii\base\View::renderFile";i:3;d:1693282692.71882891654968