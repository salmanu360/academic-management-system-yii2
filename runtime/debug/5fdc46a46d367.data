ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1608271524.58487701416015625;i:4;a:0:{}i:5;i:3221448;}i:247;a:6:{i:0;s:396:"SELECT
