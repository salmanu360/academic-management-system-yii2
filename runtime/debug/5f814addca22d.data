ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602308829.9603970050811767578125;i:4;a:0:{}i:5;i:3438400;}i:170;a:6:{i:0;s:396:"SELECT
