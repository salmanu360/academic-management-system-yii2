ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1604153933.4296510219573974609375;i:4;a:0:{}i:5;i:2419992;}i:139;a:6:{i:0;s:1977:"SELECT
    `kcu`.`CONSTRAINT_NAME` AS `name`,
