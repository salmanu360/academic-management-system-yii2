ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601710047.074902057647705078125;i:4;a:0:{}i:5;i:3320384;}i:262;a:6:{i:0;s:1977:"SELECT
