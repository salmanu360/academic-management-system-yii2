WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599277343.565537929534912109375;i:4;a:0:{}i:5;i:7433264;}i:91;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'fp6uu1ue5k1k7jsg2fuj2oqlb5', 1600486943) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1599277343.565865993499755859375;i:4;a:0:{}i:5;i:7439608;}i:92;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'fp6uu1ue5k1k7jsg2fuj2oqlb5', 1600486943) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1599277343.6491830348968505859375;i:4;a:0:{}i:5;i:7440048;}}}";s:2:"db";s:27696:"a:1:{s:8:"messages";a:48:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599277342 AND `id`='fp6uu1ue5k1k7jsg2fuj2oqlb5'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599277342.50203990936279296875;i:4;a:0:{}i:5;i:4469104;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599277342 AND `id`='fp6uu1ue5k1k7jsg2fuj2oqlb5'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599277343.1193969249725341796875;i:4;a:0:{}i:5;i:4470008;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599277343.123547077178955078125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRec