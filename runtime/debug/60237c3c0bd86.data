ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612938303.610745906829833984375;i:4;a:0:{}i:5;i:2327176;}i:157;a:6:{i:0;s:420:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:30:\"/alhuda/web/fee/fee-submission\";__id|i:1571;success|s:26:\"Fee Submitted Successfully\";', 1571, 1, 'qtk8ndmbes8vmlb87p8bsc25b4', 1614147903) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1612938303.610970973968505859375;i:4;a:0:{}i:5;i:2328384;}i:158;a:6:{i:0;s:420:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:30:\"/alhuda/web/fee/fee-submission\";__id|i:1571;success|s:26:\"Fee Submitted Successfully\";', 1571, 1, 'qtk8ndmbes8vmlb87p8bsc25b4', 1614147903) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1612938304.87362003326416015625;i:4;a:0:{}i:5;i:2328768;}}}";s:2:"db";s:61111:"a:1:{s:8:"messages";a:92:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612938298 AND `id`='qtk8ndmbes8vmlb87p8bsc25b4'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612938298.2347300052642822265625;i:4;a:0:{}i:5;i:1469680;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612938298 AND `id`='qtk8ndmbes8vmlb87p8bsc25b4'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612938298.235569000244140625;i:4;a:0:{}i:5;i:1470560;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612938298.236174106597900390625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class