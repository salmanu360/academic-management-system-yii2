ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612938446.7755959033966064453125;i:4;a:0:{}i:5;i:3219816;}i:246;a:6:{i:0;s:396:"SELECT
