ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599187935.01268291473388671875;i:4;a:0:{}i:5;i:8969744;}i:246;a:6:{i:0;s:396:"SELECT
