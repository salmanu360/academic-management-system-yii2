ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1632291882.264564990997314453125;i:4;a:0:{}i:5;i:7511728;}i:141;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '0i8jldqcq7jfubdk09q11msnl4', 1633501481) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1632291882.265120029449462890625;i:4;a:0:{}i:5;i:7517352;}i:142;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '0i8jldqcq7jfubdk09q11msnl4', 1633501481) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1632291882.26527500152587890625;i:4;a:0:{}i:5;i:7517792;}}}";s:2:"db";s:55903:"a:1:{s:8:"messages";a:80:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1632291881 AND `id`='0i8jldqcq7jfubdk09q11msnl4'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1632291881.84784698486328125;i:4;a:0:{}i:5;i:4445760;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1632291881 AND `id`='0i8jldqcq7jfubdk09q11msnl4'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1632291881.848205089569091796875;i:4;a:0:{}i:5;i:4446664;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1632291881.857080936431884765625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5221640;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:163229188