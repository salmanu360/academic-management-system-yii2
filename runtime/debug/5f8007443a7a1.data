ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602225988.699904918670654296875;i:4;a:0:{}i:5;i:5502664;}i:868;a:6:{i:0;s:396:"SELECT
