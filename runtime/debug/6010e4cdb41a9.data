ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1611719886.48237705230712890625;i:4;a:0:{}i:5;i:2270112;}i:145;a:6:{i:0;s:396:"SELECT
