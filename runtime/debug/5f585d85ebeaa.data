ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599626630.8791139125823974609375;i:4;a:0:{}i:5;i:7440880;}i:94;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'u7ieinj6el7ej6lkc91rh40603', 1600836230) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1599626630.8793809413909912109375;i:4;a:0:{}i:5;i:7447224;}i:95;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'u7ieinj6el7ej6lkc91rh40603', 1600836230) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1599626630.959269046783447265625;i:4;a:0:{}i:5;i:7447664;}}}";s:2:"db";s:28132:"a:1:{s:8:"messages";a:50:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599626629 AND `id`='u7ieinj6el7ej6lkc91rh40603'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599626629.9589850902557373046875;i:4;a:0:{}i:5;i:4469056;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599626629 AND `id`='u7ieinj6el7ej6lkc91rh40603'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599626629.959249973297119140625;i:4;a:0:{}i:5;i:4469960;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599626629.9632880687713623046875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActive