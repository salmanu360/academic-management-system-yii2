ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1684475688.698986053466796875;i:4;a:0:{}i:5;i:8733616;}i:285;a:6:{i:0;s:355:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:30:\"/alhuda/web/fee/fee-submission\";__id|i:1571;', 1571, 1, 'cej5desn45t9j489c55h2a1mn2', 1685685288) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1684475688.69921207427978515625;i:4;a:0:{}i:5;i:8800912;}i:286;a:6:{i:0;s:355:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:30:\"/alhuda/web/fee/fee-submission\";__id|i:1571;', 1571, 1, 'cej5desn45t9j489c55h2a1mn2', 1685685288) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1684475688.69954395294189453125;i:4;a:0:{}i:5;i:8801352;}}}";s:2:"db";s:125471:"a:1:{s:8:"messages";a:176:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1684475687 AND `id`='cej5desn45t9j489c55h2a1mn2'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1684475687.794972896575927734375;i:4;a:0:{}i:5;i:4452528;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1684475687 AND `id`='cej5desn45t9j489c55h2a1mn2'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1684475687.7952110767364501953125;i:4;a:0:{}i:5;i:4453464;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1684475687.80084896087646484375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5228456;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;