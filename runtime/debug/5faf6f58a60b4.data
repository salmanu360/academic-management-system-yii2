ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1605332824.9106891155242919921875;i:4;a:0:{}i:5;i:4429064;}i:577;a:6:{i:0;s:1977:"SELECT
