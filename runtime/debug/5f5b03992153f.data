ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599800217.2999899387359619140625;i:4;a:0:{}i:5;i:9168648;}i:285;a:6:{i:0;s:353:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1601009817) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1599800217.3002150058746337890625;i:4;a:0:{}i:5;i:9174944;}i:286;a:6:{i:0;s:353:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1601009817) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1599800217.4497640132904052734375;i:4;a:0:{}i:5;i:9175384;}}}";s:2:"db";s:133200:"a:1:{s:8:"messages";a:176:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599800217 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599800217.1256821155548095703125;i:4;a:0:{}i:5;i:4462024;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599800217 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599800217.1259410381317138671875;i:4;a:0:{}i:5;i:4462960;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599800217.132690906524658203125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5241624;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1