ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599540056.7667639255523681640625;i:4;a:0:{}i:5;i:8625296;}i:181;a:6:{i:0;s:396:"SELECT
