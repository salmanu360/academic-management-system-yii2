ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612760078.6810529232025146484375;i:4;a:0:{}i:5;i:3657744;}i:724;a:6:{i:0;s:408:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:37:\"Student Attendance Successfully saved\";', 1573, 1, '5kqoqutiq40utv3r216uqvl115', 1613969678) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1612760078.6812369823455810546875;i:4;a:0:{}i:5;i:3658920;}i:725;a:6:{i:0;s:408:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:37:\"Student Attendance Successfully saved\";', 1573, 1, '5kqoqutiq40utv3r216uqvl115', 1613969678) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1612760078.8879261016845703125;i:4;a:0:{}i:5;i:3659304;}}}";s:2:"db";s:232311:"a:1:{s:8:"messages";a:470:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612760073 AND `id`='5kqoqutiq40utv3r216uqvl115'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612760073.475820064544677734375;i:4;a:0:{}i:5;i:1514240;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612760073 AND `id`='5kqoqutiq40utv3r216uqvl115'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612760073.4761788845062255859375;i:4;a:0:{}i:5;i:1515088;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612760073.4777429103851318359375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\Ba