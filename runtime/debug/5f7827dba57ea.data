ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601710044.140880107879638671875;i:4;a:0:{}i:5;i:2211472;}i:91;a:6:{i:0;s:396:"SELECT
