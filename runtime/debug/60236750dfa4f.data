ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612932954.237545013427734375;i:4;a:0:{}i:5;i:3876552;}i:793;a:6:{i:0;s:408:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:37:\"Student Attendance Successfully saved\";', 1573, 1, 'kncsci0i2d7lelo0ln74nlh7l7', 1614142554) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1612932954.23775005340576171875;i:4;a:0:{}i:5;i:3877728;}i:794;a:6:{i:0;s:408:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:37:\"Student Attendance Successfully saved\";', 1573, 1, 'kncsci0i2d7lelo0ln74nlh7l7', 1614142554) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1612932954.277884960174560546875;i:4;a:0:{}i:5;i:3878112;}}}";s:2:"db";s:262816:"a:1:{s:8:"messages";a:516:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612932944 AND `id`='kncsci0i2d7lelo0ln74nlh7l7'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612932944.91203403472900390625;i:4;a:0:{}i:5;i:1514560;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612932944 AND `id`='kncsci0i2d7lelo0ln74nlh7l7'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612932944.912209987640380859375;i:4;a:0:{}i:5;i:1515616;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612932944.9131739139556884765625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActi