ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1607149299.384265899658203125;i:4;a:0:{}i:5;i:3940248;}i:559;a:6:{i:0;s:1977:"SELECT
