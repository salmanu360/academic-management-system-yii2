FROM `information_schema`.`STATISTICS` AS `s`
WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1604475203.18663311004638671875;i:4;a:0:{}i:5;i:3074656;}i:202;a:6:{i:0;s:418:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;success|s:26:\"Fee Submitted Successfully\";', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1605684803) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1604475203.186973094940185546875;i:4;a:0:{}i:5;i:3076152;}i:203;a:6:{i:0;s:418:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;success|s:26:\"Fee Submitted Successfully\";', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1605684803) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1604475203.2411649227142333984375;i:4;a:0:{}i:5;i:3076536;}}}";s:2:"db";s:77739:"a:1:{s:8:"messages";a:122:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1604475200 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1604475200.449512958526611328125;i:4;a:0:{}i:5;i:1817104;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1604475200 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1604475200.4497730731964111328125;i:4;a:0:{}i:5;i:1817984;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1604475200.4561650753021240234375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"cla