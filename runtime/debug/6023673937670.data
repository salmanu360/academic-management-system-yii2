ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612932921.5706789493560791015625;i:4;a:0:{}i:5;i:2891296;}i:189;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'kncsci0i2d7lelo0ln74nlh7l7', 1614142521) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1612932921.5708420276641845703125;i:4;a:0:{}i:5;i:2892392;}i:190;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'kncsci0i2d7lelo0ln74nlh7l7', 1614142521) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1612932921.62397289276123046875;i:4;a:0:{}i:5;i:2892776;}}}";s:2:"db";s:84557:"a:1:{s:8:"messages";a:112:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612932921 AND `id`='kncsci0i2d7lelo0ln74nlh7l7'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612932921.223618984222412109375;i:4;a:0:{}i:5;i:1457704;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612932921 AND `id`='kncsci0i2d7lelo0ln74nlh7l7'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612932921.2238309383392333984375;i:4;a:0:{}i:5;i:1458552;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612932921.2245690822601318359375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1605872;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d: