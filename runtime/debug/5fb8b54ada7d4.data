ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1605940558.4058039188385009765625;i:4;a:0:{}i:5;i:3057336;}i:193;a:6:{i:0;s:396:"SELECT
