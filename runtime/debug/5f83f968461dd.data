ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602484584.3992049694061279296875;i:4;a:0:{}i:5;i:3416072;}i:285;a:6:{i:0;s:353:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1603694184) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1602484584.39937591552734375;i:4;a:0:{}i:5;i:3417200;}i:286;a:6:{i:0;s:353:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1603694184) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1602484584.4938809871673583984375;i:4;a:0:{}i:5;i:3417584;}}}";s:2:"db";s:133208:"a:1:{s:8:"messages";a:176:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1602484584 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1602484584.28466892242431640625;i:4;a:0:{}i:5;i:1457944;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1602484584 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602484584.28487110137939453125;i:4;a:0:{}i:5;i:1458824;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1602484584.2854750156402587890625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1606160;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i: