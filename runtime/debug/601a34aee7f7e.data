ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612330159.2267949581146240234375;i:4;a:0:{}i:5;i:4341272;}i:428;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '215hcvo8lq5p679b4dpsk9ug03', 1613539759) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1612330159.226972103118896484375;i:4;a:0:{}i:5;i:4342368;}i:429;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '215hcvo8lq5p679b4dpsk9ug03', 1613539759) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1612330159.96768093109130859375;i:4;a:0:{}i:5;i:4342752;}}}";s:2:"db";s:219258:"a:1:{s:8:"messages";a:266:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612330158 AND `id`='215hcvo8lq5p679b4dpsk9ug03'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612330158.947598934173583984375;i:4;a:0:{}i:5;i:1455832;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612330158 AND `id`='215hcvo8lq5p679b4dpsk9ug03'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612330158.947772979736328125;i:4;a:0:{}i:5;i:1456680;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612330158.9484670162200927734375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1604000;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612