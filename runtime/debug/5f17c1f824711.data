ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1595392505.2884581089019775390625;i:4;a:0:{}i:5;i:7438936;}i:94;a:6:{i:0;s:376:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'divskbvur396ng3n8eiecibmi5', 1596602105) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1595392505.2886960506439208984375;i:4;a:0:{}i:5;i:7445248;}i:95;a:6:{i:0;s:376:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'divskbvur396ng3n8eiecibmi5', 1596602105) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1595392505.6575949192047119140625;i:4;a:0:{}i:5;i:7445688;}}}";s:2:"db";s:28079:"a:1:{s:8:"messages";a:50:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1595392503 AND `id`='divskbvur396ng3n8eiecibmi5'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1595392503.778563022613525390625;i:4;a:0:{}i:5;i:4469256;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1595392503 AND `id`='divskbvur396ng3n8eiecibmi5'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1595392503.77873706817626953125;i:4;a:0:{}i:5;i:4470136;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1595392503.782823085784912109375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5248704;}i:13;a:6:{i:0;s