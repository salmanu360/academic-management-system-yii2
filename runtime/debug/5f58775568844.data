    kcu.constraint_name,
    kcu.column_name,
    kcu.referenced_table_name,
    kcu.referenced_column_name
FROM information_schema.referential_constraints AS rc
JOIN information_schema.key_column_usage AS kcu ON
    (
        kcu.constraint_catalog = rc.constraint_catalog OR
        (kcu.constraint_catalog IS NULL AND rc.constraint_catalog IS NULL)
    ) AND
    kcu.constraint_schema = rc.constraint_schema AND
    kcu.constraint_name = rc.constraint_name
WHERE rc.constraint_schema = database() AND kcu.table_schema = database()
AND rc.table_name = 'sms_settings' AND kcu.table_name = 'sms_settings'";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1599633239.219397068023681640625;i:4;a:2:{i:0;a:5:{s:4:"file";s:56:"/home/onnviiod/public_html/alhuda/views/layouts/main.php";s:4:"line";i:374;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:67:"/home/onnviiod/public_html/alhuda/controllers/StudentController.php";s:4:"line";i:3247;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:12202104;}i:832;a:6:{i:0;s:96:"Rendering view file: /home/onnviiod/public_html/alhuda/views/layouts/menuroles/administrator.php";i:1;i:8;i:2;s:25:"yii\base\View::renderFile";i:3;d:1599633239.219760894775390625;i:4;a:2:{i:0;a:5:{s:4:"file";s:56:"/home/onnviiod/public_html/alhuda/views/layouts/main.php";s:4:"line";i:401;s:8:"function";s:6:"render";s:5:"class";s:13:"yii\base\View";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:67:"/home/onnviiod/public_html/alhuda/controllers/StudentController.php";s:4:"line";i:3247;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:12199576;}i:833;a:6:{i:0;s:80:"Rendering view file: /home/onnviiod/public_html/alhuda/views/layouts/sidebar.php";i:1;i:8;i:2;s:25:"yii\base\View::renderFile";i:3;d:1599633239.223577022552490234375;i:4;a:2:{i:0;a:5:{s:4:"file";s:56:"/home/onnviiod/public_html/alhuda/views/layouts/main.php";s:4:"line";i:429;s:8:"function";s:6:"render";s:5:"class";s:13:"yii\base\View";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:67:"/home/onnviiod/public_html/alhuda/controllers/StudentController.php";s:4:"line";i:3247;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:12481680;}i:834;a:6:{i:0;s:101:"Access to debugger is denied due to IP address restriction. The requesting IP address is 39.33.39.142";i:1;i:2;i:2;s:29:"yii\debug\Module::checkAccess";i:3;d:1599633239.2236759662628173828125;i:4;a:2:{i:0;a: