ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1690948762.582539081573486328125;i:4;a:0:{}i:5;i:26453520;}i:3731;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '7n92j96q5mh5kcd7pr8642dmq0', 1692158362) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1690948762.5828149318695068359375;i:4;a:0:{}i:5;i:26459144;}i:3732;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '7n92j96q5mh5kcd7pr8642dmq0', 1692158362) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1690948762.5831930637359619140625;i:4;a:0:{}i:5;i:26459584;}}}";s:2:"db";s:1538046:"a:1:{s:8:"messages";a:2468:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1690948761 AND `id`='7n92j96q5mh5kcd7pr8642dmq0'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1690948761.4770219326019287109375;i:4;a:0:{}i:5;i:4443480;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1690948761 AND `id`='7n92j96q5mh5kcd7pr8642dmq0'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1690948761.477324008941650390625;i:4;a:0:{}i:5;i:4444384;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1690948761.4811561107635498046875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5219360;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::quer