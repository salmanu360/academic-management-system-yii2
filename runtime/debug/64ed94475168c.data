    `information_schema`.`TABLE_CONSTRAINTS` AS `tc`
WHERE
    `kcu`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `kcu`.`TABLE_NAME` = 'session'
    AND `tc`.`TABLE_SCHEMA` = `kcu`.`TABLE_SCHEMA` AND `tc`.`TABLE_NAME` = 'session' AND `tc`.`CONSTRAINT_NAME` = `kcu`.`CONSTRAINT_NAME` AND `tc`.`CONSTRAINT_TYPE` IN ('PRIMARY KEY', 'UNIQUE')
ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1693291637.1017429828643798828125;i:4;a:0:{}i:5;i:12984856;}}}";s:2:"db";s:909491:"a:1:{s:8:"messages";a:1101:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1693291591 AND `id`='iak9b2h8k32uq636nn8se8c6b7'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1693291591.3179008960723876953125;i:4;a:0:{}i:5;i:4444432;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1693291591 AND `id`='iak9b2h8k32uq636nn8se8c6b7'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1693291591.3188989162445068359375;i:4;a:0:{}i:5;i:4445368;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1693291591.329245090484619140625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5220360;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1693291591.32991790771484375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5243520;}i:15;a:6:{i:0;s:609:"SELECT
