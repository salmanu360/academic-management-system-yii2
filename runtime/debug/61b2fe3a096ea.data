ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1639120443.549746036529541015625;i:4;a:0:{}i:5;i:21803616;}i:1149;a:6:{i:0;s:396:"SELECT
