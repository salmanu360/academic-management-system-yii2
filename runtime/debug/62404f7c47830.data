ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1648381822.0820009708404541015625;i:4;a:0:{}i:5;i:7902448;}i:158;a:6:{i:0;s:330:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:580;', 580, 1, 'c7e0urkbqcda03bhos1jhat3d2', 1649591420) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1648381822.08238697052001953125;i:4;a:0:{}i:5;i:7908072;}i:159;a:6:{i:0;s:330:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:580;', 580, 1, 'c7e0urkbqcda03bhos1jhat3d2', 1649591420) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1648381822.082767963409423828125;i:4;a:0:{}i:5;i:7908512;}}}";s:2:"db";s:57207:"a:1:{s:8:"messages";a:88:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1648381820 AND `id`='c7e0urkbqcda03bhos1jhat3d2'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1648381820.265904903411865234375;i:4;a:0:{}i:5;i:4448744;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1648381820 AND `id`='c7e0urkbqcda03bhos1jhat3d2'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1648381820.266418933868408203125;i:4;a:0:{}i:5;i:4449648;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1648381820.2828080654144287109375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5224624;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1648381