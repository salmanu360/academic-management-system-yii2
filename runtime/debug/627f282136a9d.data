ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1652500514.672832012176513671875;i:4;a:0:{}i:5;i:25420248;}i:3266;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'n731oiuj1tfpk8lkec1dlsrf55', 1653710114) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1652500514.6732399463653564453125;i:4;a:0:{}i:5;i:25425872;}i:3267;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'n731oiuj1tfpk8lkec1dlsrf55', 1653710114) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1652500514.6736240386962890625;i:4;a:0:{}i:5;i:25426312;}}}";s:2:"db";s:1345575:"a:1:{s:8:"messages";a:2158:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1652500513 AND `id`='n731oiuj1tfpk8lkec1dlsrf55'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1652500513.2155430316925048828125;i:4;a:0:{}i:5;i:4443984;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1652500513 AND `id`='n731oiuj1tfpk8lkec1dlsrf55'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1652500513.21603107452392578125;i:4;a:0:{}i:5;i:4444888;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1652500513.2208130359649658203125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5219864;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1652500513.2213420867919921875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5243024;}i:15;a:6:{i:0;s:609:"SELECT
    kcu.constraint_name,
    kcu.column_name,
    kcu.referenced_table_name,
    kcu.referenced_column_name
FROM information_schema.referential_constraints AS rc
JOIN information_schema.key_column_usage AS kcu ON
    (
        kcu.constraint_catalog = rc.constraint_catalog OR
        (kcu.constraint_catalog IS NULL AND rc.constraint_catalog IS NULL)
    ) AND
    kcu.constraint_schema = rc.constraint_schema AND
    kcu.constraint_name = rc.constraint_name
WHERE rc.constraint_schema = database() AND kcu.table_schema = database()
AND rc.table_name = 'user' AND kcu.table_name = 'user'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1652500513.2218248844146728515625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5261976;}i:16;a:6:{i:0;s:609:"SELECT
    kcu.constraint_name,
    kcu.column_name,
    kcu.referenced_table_name,
    kcu.referenced_column_name
FROM information_schema.referential_constraints AS rc
JOIN information_schema.key_column_usage AS kcu ON
    (
        kcu.constraint_catalog = rc.constraint_catalog OR
        (kcu.constraint_catalog IS NULL AND rc.constraint_catalog IS NULL)
    ) AND
    kcu.constraint_schema = rc.constraint_schema AND
