ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1609912301.9125149250030517578125;i:4;a:0:{}i:5;i:3224992;}i:246;a:6:{i:0;s:396:"SELECT
