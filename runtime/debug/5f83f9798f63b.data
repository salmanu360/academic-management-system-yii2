ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602484602.3445889949798583984375;i:4;a:0:{}i:5;i:2269592;}i:145;a:6:{i:0;s:396:"SELECT
