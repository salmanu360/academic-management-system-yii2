ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612158160.035027980804443359375;i:4;a:0:{}i:5;i:2664960;}i:153;a:6:{i:0;s:396:"SELECT
