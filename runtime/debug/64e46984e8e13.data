ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1692690821.1135540008544921875;i:4;a:0:{}i:5;i:8987592;}i:253;a:6:{i:0;s:396:"SELECT
