ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1606034409.6653840541839599609375;i:4;a:0:{}i:5;i:2437352;}i:193;a:6:{i:0;s:396:"SELECT
