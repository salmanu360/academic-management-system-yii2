ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612844468.4651229381561279296875;i:4;a:0:{}i:5;i:6808536;}i:1076;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '9gpo3upmi3oq8v8j2v7erl97n0', 1614054068) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1612844468.465321063995361328125;i:4;a:0:{}i:5;i:6809632;}i:1077;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '9gpo3upmi3oq8v8j2v7erl97n0', 1614054068) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1612844468.59918689727783203125;i:4;a:0:{}i:5;i:6810016;}}}";s:2:"db";s:539951:"a:1:{s:8:"messages";a:698:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612844467 AND `id`='9gpo3upmi3oq8v8j2v7erl97n0'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612844467.95137500762939453125;i:4;a:0:{}i:5;i:1455800;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612844467 AND `id`='9gpo3upmi3oq8v8j2v7erl97n0'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612844467.9516201019287109375;i:4;a:0:{}i:5;i:1456648;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612844467.9525310993194580078125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1603968;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:16