ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1611554352.9817368984222412109375;i:4;a:0:{}i:5;i:2269568;}i:145;a:6:{i:0;s:396:"SELECT
