ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601911208.7688810825347900390625;i:4;a:0:{}i:5;i:2415824;}i:140;a:6:{i:0;s:299:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__id|i:80;', 80, 1, 'uptr0utabgtfnnnpup5c9ffcu7', 1603120808) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1601911208.7690699100494384765625;i:4;a:0:{}i:5;i:2416896;}i:141;a:6:{i:0;s:299:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__id|i:80;', 80, 1, 'uptr0utabgtfnnnpup5c9ffcu7', 1603120808) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1601911209.02789592742919921875;i:4;a:0:{}i:5;i:2417280;}}}";s:2:"db";s:50367:"a:1:{s:8:"messages";a:76:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1601911208 AND `id`='uptr0utabgtfnnnpup5c9ffcu7'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601911208.450643062591552734375;i:4;a:0:{}i:5;i:1458864;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1601911208 AND `id`='uptr0utabgtfnnnpup5c9ffcu7'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601911208.4508359432220458984375;i:4;a:0:{}i:5;i:1459688;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601911208.4514520168304443359375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1606928;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601911208.4518749713897705078125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49