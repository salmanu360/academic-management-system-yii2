ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601271814.2436730861663818359375;i:4;a:0:{}i:5;i:7440800;}i:94;a:6:{i:0;s:442:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:44:\"/alhuda/web/student/official?id=MTcwMw%3D%3D\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'bi7jh9djnabn5sfouvchsha7h7', 1602481414) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1601271814.243957042694091796875;i:4;a:0:{}i:5;i:7447176;}i:95;a:6:{i:0;s:442:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:44:\"/alhuda/web/student/official?id=MTcwMw%3D%3D\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'bi7jh9djnabn5sfouvchsha7h7', 1602481414) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1601271814.2802050113677978515625;i:4;a:0:{}i:5;i:7447616;}}}";s:2:"db";s:28244:"a:1:{s:8:"messages";a:50:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1601271814 AND `id`='bi7jh9djnabn5sfouvchsha7h7'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601271814.060657978057861328125;i:4;a:0:{}i:5;i:4468920;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1601271814 AND `id`='bi7jh9djnabn5sfouvchsha7h7'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601271814.0608990192413330078125;i:4;a:0:{}i:5;i:4469968;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601271814.0647408962249755859375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"li