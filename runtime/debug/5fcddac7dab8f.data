ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1607326408.0427520275115966796875;i:4;a:0:{}i:5;i:3472008;}i:294;a:6:{i:0;s:396:"SELECT
