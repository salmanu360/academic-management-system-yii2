ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1692698112.5511510372161865234375;i:4;a:0:{}i:5;i:7846672;}i:146;a:6:{i:0;s:299:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__id|i:80;', 80, 1, '1topdkvgtb0cegrn6gd3tpj8c1', 1693907712) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1692698112.5514190196990966796875;i:4;a:0:{}i:5;i:7852272;}i:147;a:6:{i:0;s:299:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__id|i:80;', 80, 1, '1topdkvgtb0cegrn6gd3tpj8c1', 1693907712) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1692698112.5517671108245849609375;i:4;a:0:{}i:5;i:7852712;}}}";s:2:"db";s:52592:"a:1:{s:8:"messages";a:80:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1692698112 AND `id`='1topdkvgtb0cegrn6gd3tpj8c1'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1692698112.19542694091796875;i:4;a:0:{}i:5;i:4444808;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1692698112 AND `id`='1topdkvgtb0cegrn6gd3tpj8c1'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1692698112.1956779956817626953125;i:4;a:0:{}i:5;i:4445688;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1692698112.1993200778961181640625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5220584;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1692698112.199799060821533203125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/