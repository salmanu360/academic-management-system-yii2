ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1596042209.6672699451446533203125;i:4;a:0:{}i:5;i:8365256;}i:333;a:6:{i:0;s:301:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__id|i:552;', 552, 1, '14ljckt39msfiht3fsscb13b72', 1597251809) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1596042209.6674969196319580078125;i:4;a:0:{}i:5;i:8371496;}i:334;a:6:{i:0;s:301:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__id|i:552;', 552, 1, '14ljckt39msfiht3fsscb13b72', 1597251809) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1596042209.755013942718505859375;i:4;a:0:{}i:5;i:8371936;}}}";s:2:"db";s:132913:"a:1:{s:8:"messages";a:206:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1596042208 AND `id`='14ljckt39msfiht3fsscb13b72'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1596042208.8663771152496337890625;i:4;a:0:{}i:5;i:4457560;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1596042208 AND `id`='14ljckt39msfiht3fsscb13b72'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1596042208.8665549755096435546875;i:4;a:0:{}i:5;i:4458440;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1596042208.870315074920654296875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5237008;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1596042208.8708269596099853515625;i:4;a:1:{i:0;a:5:{s:4:"fil