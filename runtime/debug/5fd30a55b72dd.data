ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1607666262.157000064849853515625;i:4;a:0:{}i:5;i:4427752;}i:577;a:6:{i:0;s:1977:"SELECT
