ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1607499819.3059589862823486328125;i:4;a:0:{}i:5;i:3476408;}i:294;a:6:{i:0;s:396:"SELECT
