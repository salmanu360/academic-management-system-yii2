ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601006648.650981903076171875;i:4;a:0:{}i:5;i:10355832;}i:577;a:6:{i:0;s:1977:"SELECT
