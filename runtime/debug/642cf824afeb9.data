ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1680668710.1954081058502197265625;i:4;a:0:{}i:5;i:25606256;}i:3344;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '7d70sa23bqao3r2h3te9mi7546', 1681878310) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1680668710.195713043212890625;i:4;a:0:{}i:5;i:25611880;}i:3345;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '7d70sa23bqao3r2h3te9mi7546', 1681878310) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1680668710.19608402252197265625;i:4;a:0:{}i:5;i:25612320;}}}";s:2:"db";s:1377940:"a:1:{s:8:"messages";a:2210:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1680668708 AND `id`='7d70sa23bqao3r2h3te9mi7546'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1680668708.7104070186614990234375;i:4;a:0:{}i:5;i:4451888;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1680668708 AND `id`='7d70sa23bqao3r2h3te9mi7546'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1680668708.710784912109375;i:4;a:0:{}i:5;i:4452792;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1680668708.7162940502166748046875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5227768;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:16