WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1667189564.5215389728546142578125;i:4;a:0:{}i:5;i:26193856;}i:3614;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'c7t1opj1uibckcp0cdqovp1t07', 1668399164) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1667189564.5218219757080078125;i:4;a:0:{}i:5;i:26199480;}i:3615;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'c7t1opj1uibckcp0cdqovp1t07', 1668399164) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1667189564.522190093994140625;i:4;a:0:{}i:5;i:26199920;}}}";s:2:"db";s:1489462:"a:1:{s:8:"messages";a:2390:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1667189562 AND `id`='c7t1opj1uibckcp0cdqovp1t07'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1667189563.0018160343170166015625;i:4;a:0:{}i:5;i:4443984;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1667189562 AND `id`='c7t1opj1uibckcp0cdqovp1t07'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1667189563.0020771026611328125;i:4;a:0:{}i:5;i:4444888;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1667189563.0065810680389404296875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5219864;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d