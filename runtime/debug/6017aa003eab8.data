    kcu.constraint_name,
    kcu.column_name,
    kcu.referenced_table_name,
    kcu.referenced_column_name
FROM information_schema.referential_constraints AS rc
JOIN information_schema.key_column_usage AS kcu ON
    (
        kcu.constraint_catalog = rc.constraint_catalog OR
        (kcu.constraint_catalog IS NULL AND rc.constraint_catalog IS NULL)
    ) AND
    kcu.constraint_schema = rc.constraint_schema AND
    kcu.constraint_name = rc.constraint_name
WHERE rc.constraint_schema = database() AND kcu.table_schema = database()
AND rc.table_name = 'fee_arears' AND kcu.table_name = 'fee_arears'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612163584.39002704620361328125;i:4;a:2:{i:0;a:5:{s:4:"file";s:80:"/home/onnviiod/public_html/alhuda/views/fee/report/currentmonth-fee-slip-pdf.php";s:4:"line";i:193;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:63:"/home/onnviiod/public_html/alhuda/controllers/FeeController.php";s:4:"line";i:761;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:2843584;}i:200;a:6:{i:0;s:621:"SELECT
