ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599808038.8291759490966796875;i:4;a:0:{}i:5;i:8941632;}i:241;a:6:{i:0;s:396:"SELECT
