                   ((abc.No_Of_Student)/
                    (SELECT count(*) FROM  student_info si2 
                    inner join ref_class rc on rc.class_id=si2.class_id
                    where si2.fk_branch_id='1' and rc.title= 'NUR' and si2.is_active =1))* 100
                    as `Percentage_of_newly_admitted_student`
