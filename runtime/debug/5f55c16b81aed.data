      select st.stu_id as `student id`,concat(u.first_name,' ',u.middle_name,' ' ,u.last_name) as `student_name`, st.class_id as `class_id`,rc.title as `class_name`,st.group_id as `group id`,rg.title as `group_name`,st.section_id as `section_id`,rs.title as `section_name` from student_info st inner join student_parents_info spi on spi.stu_id=st.stu_id inner join ref_class rc on rc.class_id = st.class_id left join ref_group rg on rg.group_id=st.group_id left join ref_section rs on rs.section_id=st.section_id inner join user u on u.id=st.user_id where spi.cnic='15302-_______-_' and st.fk_branch_id='1' and st.is_active='1'
