ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1607929611.42078304290771484375;i:4;a:0:{}i:5;i:2400232;}i:87;a:6:{i:0;s:355:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:30:\"/alhuda/web/fee/fee-submission\";__id|i:1571;', 1571, 1, 'qtk8ndmbes8vmlb87p8bsc25b4', 1609139211) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1607929611.4209530353546142578125;i:4;a:0:{}i:5;i:2401360;}i:88;a:6:{i:0;s:355:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:30:\"/alhuda/web/fee/fee-submission\";__id|i:1571;', 1571, 1, 'qtk8ndmbes8vmlb87p8bsc25b4', 1609139211) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1607929611.5529029369354248046875;i:4;a:0:{}i:5;i:2401744;}}}";s:2:"db";s:33856:"a:1:{s:8:"messages";a:44:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1607929611 AND `id`='qtk8ndmbes8vmlb87p8bsc25b4'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1607929611.3006980419158935546875;i:4;a:0:{}i:5;i:1457904;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1607929611 AND `id`='qtk8ndmbes8vmlb87p8bsc25b4'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1607929611.3008821010589599609375;i:4;a:0:{}i:5;i:1458784;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1607929611.3015639781951904296875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1606120;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;