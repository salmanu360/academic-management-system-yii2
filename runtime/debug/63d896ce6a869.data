ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1675138767.3532640933990478515625;i:4;a:0:{}i:5;i:23971296;}i:2624;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'cd92if6a9iprk6odh6dc1kk7o0', 1676348367) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1675138767.35356807708740234375;i:4;a:0:{}i:5;i:23976920;}i:2625;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'cd92if6a9iprk6odh6dc1kk7o0', 1676348367) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1675138767.3538970947265625;i:4;a:0:{}i:5;i:23977360;}}}";s:2:"db";s:1080416:"a:1:{s:8:"messages";a:1730:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1675138766 AND `id`='cd92if6a9iprk6odh6dc1kk7o0'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1675138766.4287090301513671875;i:4;a:0:{}i:5;i:4445584;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1675138766 AND `id`='cd92if6a9iprk6odh6dc1kk7o0'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1675138766.4290618896484375;i:4;a:0:{}i:5;i:4446488;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1675138766.433206081390380859375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5221464;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1675138