ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1603424839.8985440731048583984375;i:4;a:0:{}i:5;i:5260552;}i:726;a:6:{i:0;s:396:"SELECT
    `s`.`INDEX_NAME` AS `name`,
