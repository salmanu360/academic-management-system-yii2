FROM `information_schema`.`STATISTICS` AS `s`
WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1603174237.558514118194580078125;i:4;a:0:{}i:5;i:6808144;}i:1076;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'v85ddkdgsn60au7aplmf0bneg7', 1604383837) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1603174237.5587170124053955078125;i:4;a:0:{}i:5;i:6809240;}i:1077;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'v85ddkdgsn60au7aplmf0bneg7', 1604383837) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1603174238.344255924224853515625;i:4;a:0:{}i:5;i:6809624;}}}";s:2:"db";s:539872:"a:1:{s:8:"messages";a:698:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1603174236 AND `id`='v85ddkdgsn60au7aplmf0bneg7'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1603174236.30821895599365234375;i:4;a:0:{}i:5;i:1455768;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1603174236 AND `id`='v85ddkdgsn60au7aplmf0bneg7'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1603174236.308453083038330078125;i:4;a:0:{}i:5;i:1456616;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1603174236.3090450763702392578125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1603936;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d