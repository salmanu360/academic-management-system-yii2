ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1635732215.109920024871826171875;i:4;a:0:{}i:5;i:9032768;}i:666;a:6:{i:0;s:396:"SELECT
