ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1597725330.831439971923828125;i:4;a:0:{}i:5;i:6938936;}i:112;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'nuthjjj4q48i0jc1unqr7u9087', 1598934930) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1597725330.8317320346832275390625;i:4;a:0:{}i:5;i:6945200;}i:113;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'nuthjjj4q48i0jc1unqr7u9087', 1598934930) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1597725330.8318920135498046875;i:4;a:0:{}i:5;i:6945640;}}}";s:2:"db";s:40034:"a:1:{s:8:"messages";a:62:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1597725330 AND `id`='nuthjjj4q48i0jc1unqr7u9087'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1597725330.3812520503997802734375;i:4;a:0:{}i:5;i:4461960;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1597725330 AND `id`='nuthjjj4q48i0jc1unqr7u9087'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1597725330.38185405731201171875;i:4;a:0:{}i:5;i:4462864;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1597725330.3894999027252197265625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5241512;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1597725