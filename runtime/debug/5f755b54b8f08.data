FROM `information_schema`.`STATISTICS` AS `s`
WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601526612.9072840213775634765625;i:4;a:0:{}i:5;i:7435504;}i:91;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, '1cvctuedb2c87mqlt3uoj5ukf5', 1602736212) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1601526612.90756988525390625;i:4;a:0:{}i:5;i:7441848;}i:92;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, '1cvctuedb2c87mqlt3uoj5ukf5', 1602736212) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1601526612.9563090801239013671875;i:4;a:0:{}i:5;i:7442288;}}}";s:2:"db";s:27756:"a:1:{s:8:"messages";a:48:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1601526612 AND `id`='1cvctuedb2c87mqlt3uoj5ukf5'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601526612.7509920597076416015625;i:4;a:0:{}i:5;i:4469248;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1601526612 AND `id`='1cvctuedb2c87mqlt3uoj5ukf5'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601526612.7511761188507080078125;i:4;a:0:{}i:5;i:4470152;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601526612.755012035369873046875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveReco