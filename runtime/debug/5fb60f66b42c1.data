ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1605767015.32507991790771484375;i:4;a:0:{}i:5;i:6183656;}i:1078;a:6:{i:0;s:396:"SELECT
