ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1630379600.2833690643310546875;i:4;a:0:{}i:5;i:21628736;}i:1634;a:6:{i:0;s:348:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:23:\"/alhuda/web/student/cal\";__id|i:1573;', 1573, 1, 'b5uqam9nhdfujvt0turlvd85d2', 1631589199) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1630379600.2839450836181640625;i:4;a:0:{}i:5;i:21699912;}i:1635;a:6:{i:0;s:348:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:23:\"/alhuda/web/student/cal\";__id|i:1573;', 1573, 1, 'b5uqam9nhdfujvt0turlvd85d2', 1631589199) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1630379600.2843220233917236328125;i:4;a:0:{}i:5;i:21700352;}}}";s:2:"db";s:672350:"a:1:{s:8:"messages";a:1070:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1630379599 AND `id`='b5uqam9nhdfujvt0turlvd85d2'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1630379599.5380399227142333984375;i:4;a:0:{}i:5;i:4443984;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1630379599 AND `id`='b5uqam9nhdfujvt0turlvd85d2'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1630379599.53849697113037109375;i:4;a:0:{}i:5;i:4444904;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1630379599.5437819957733154296875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5219888;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s