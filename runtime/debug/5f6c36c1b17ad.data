ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1600927425.9349191188812255859375;i:4;a:0:{}i:5;i:7440864;}i:94;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 're1g8t58n75o29te6t4npom9m7', 1602137025) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1600927425.9351680278778076171875;i:4;a:0:{}i:5;i:7447208;}i:95;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 're1g8t58n75o29te6t4npom9m7', 1602137025) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1600927426.0299770832061767578125;i:4;a:0:{}i:5;i:7447648;}}}";s:2:"db";s:28183:"a:1:{s:8:"messages";a:50:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1600927425 AND `id`='re1g8t58n75o29te6t4npom9m7'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1600927425.72082805633544921875;i:4;a:0:{}i:5;i:4469040;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1600927425 AND `id`='re1g8t58n75o29te6t4npom9m7'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1600927425.7210209369659423828125;i:4;a:0:{}i:5;i:4469944;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1600927425.72459506988525390625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRe