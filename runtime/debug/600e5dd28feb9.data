ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1611554259.3841340541839599609375;i:4;a:0:{}i:5;i:2269216;}i:145;a:6:{i:0;s:396:"SELECT
