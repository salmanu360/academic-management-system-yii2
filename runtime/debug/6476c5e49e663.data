ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1685505509.6456429958343505859375;i:4;a:0:{}i:5;i:26201792;}i:3614;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'cg0gkshc0459ptstf107a03a74', 1686715109) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1685505509.6459128856658935546875;i:4;a:0:{}i:5;i:26207416;}i:3615;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'cg0gkshc0459ptstf107a03a74', 1686715109) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1685505509.6461451053619384765625;i:4;a:0:{}i:5;i:26207856;}}}";s:2:"db";s:1490067:"a:1:{s:8:"messages";a:2390:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1685505508 AND `id`='cg0gkshc0459ptstf107a03a74'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1685505508.64089298248291015625;i:4;a:0:{}i:5;i:4451888;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1685505508 AND `id`='cg0gkshc0459ptstf107a03a74'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1685505508.6411468982696533203125;i:4;a:0:{}i:5;i:4452792;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1685505508.6457970142364501953125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5227768;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::quer