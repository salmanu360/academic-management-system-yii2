ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1607494395.2596209049224853515625;i:4;a:0:{}i:5;i:3220680;}i:246;a:6:{i:0;s:396:"SELECT
