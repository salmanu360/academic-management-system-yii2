ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1688209630.79055309295654296875;i:4;a:0:{}i:5;i:9183784;}i:145;a:6:{i:0;s:1977:"SELECT
