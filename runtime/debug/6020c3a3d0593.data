ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612759975.8298680782318115234375;i:4;a:0:{}i:5;i:3705632;}i:724;a:6:{i:0;s:408:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:37:\"Student Attendance Successfully saved\";', 1573, 1, '5kqoqutiq40utv3r216uqvl115', 1613969575) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1612759975.8300740718841552734375;i:4;a:0:{}i:5;i:3706808;}i:725;a:6:{i:0;s:408:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:37:\"Student Attendance Successfully saved\";', 1573, 1, '5kqoqutiq40utv3r216uqvl115', 1613969575) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1612759975.886692047119140625;i:4;a:0:{}i:5;i:3707192;}}}";s:2:"db";s:238597:"a:1:{s:8:"messages";a:470:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612759971 AND `id`='5kqoqutiq40utv3r216uqvl115'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612759971.850327014923095703125;i:4;a:0:{}i:5;i:1513600;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612759971 AND `id`='5kqoqutiq40utv3r216uqvl115'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612759971.8504970073699951171875;i:4;a:0:{}i:5;i:1514448;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612759971.8511559963226318359375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\Bas