ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1682753855.262031078338623046875;i:4;a:0:{}i:5;i:24776560;}i:2982;a:6:{i:0;s:1977:"SELECT
