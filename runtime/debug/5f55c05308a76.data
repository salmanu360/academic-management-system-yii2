FROM `information_schema`.`STATISTICS` AS `s`
WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599455316.591053009033203125;i:4;a:0:{}i:5;i:7433416;}i:91;a:6:{i:0;s:443:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:45:\"/alhuda/web/student/education?id=MjIwNw%3D%3D\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, '1b5sejcqs24vofvbt39kmis780', 1600664915) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1599455316.59130191802978515625;i:4;a:0:{}i:5;i:7439792;}i:92;a:6:{i:0;s:443:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:45:\"/alhuda/web/student/education?id=MjIwNw%3D%3D\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, '1b5sejcqs24vofvbt39kmis780', 1600664915) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1599455316.8829309940338134765625;i:4;a:0:{}i:5;i:7440232;}}}";s:2:"db";s:27807:"a:1:{s:8:"messages";a:48:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599455315 AND `id`='1b5sejcqs24vofvbt39kmis780'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599455315.028542041778564453125;i:4;a:0:{}i:5;i:4469168;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599455315 AND `id`='1b5sejcqs24vofvbt39kmis780'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599455315.028728008270263671875;i:4;a:0:{}i:5;i:4470216;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599455315.0328080654144287109375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";