ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599187426.4689199924468994140625;i:4;a:0:{}i:5;i:8715824;}i:199;a:6:{i:0;s:396:"SELECT
