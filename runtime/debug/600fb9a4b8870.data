ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1611643301.13370800018310546875;i:4;a:0:{}i:5;i:4378832;}i:298;a:6:{i:0;s:396:"SELECT
