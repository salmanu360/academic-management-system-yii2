ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612587877.3532340526580810546875;i:4;a:0:{}i:5;i:2988768;}i:199;a:6:{i:0;s:1977:"SELECT
