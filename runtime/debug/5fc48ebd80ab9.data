ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1606717117.7470700740814208984375;i:4;a:0:{}i:5;i:4427584;}i:577;a:6:{i:0;s:1977:"SELECT
