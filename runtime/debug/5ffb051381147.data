ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1610286356.9534580707550048828125;i:4;a:0:{}i:5;i:2440480;}i:146;a:6:{i:0;s:301:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__id|i:619;', 619, 1, 'mcq09fussd2tc3huctpv11lk35', 1611495956) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1610286356.9536449909210205078125;i:4;a:0:{}i:5;i:2507088;}i:147;a:6:{i:0;s:301:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__id|i:619;', 619, 1, 'mcq09fussd2tc3huctpv11lk35', 1611495956) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1610286357.0803539752960205078125;i:4;a:0:{}i:5;i:2507472;}}}";s:2:"db";s:52646:"a:1:{s:8:"messages";a:80:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1610286355 AND `id`='mcq09fussd2tc3huctpv11lk35'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1610286355.5262930393218994140625;i:4;a:0:{}i:5;i:1458864;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1610286355 AND `id`='mcq09fussd2tc3huctpv11lk35'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1610286355.5264909267425537109375;i:4;a:0:{}i:5;i:1459688;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1610286355.5270950794219970703125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1606928;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1610286355.5275180339813232421875;i:4;a:1:{i:0;a:5:{s:4:"fil