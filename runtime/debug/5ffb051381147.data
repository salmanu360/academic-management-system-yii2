ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1610286356.9531390666961669921875;i:4;a:0:{}i:5;i:2438904;}i:144;a:6:{i:0;s:396:"SELECT
