WHERE rc.constraint_schema = database() AND kcu.table_schema = database()
AND rc.table_name = 'fee_submission' AND kcu.table_name = 'fee_submission'";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1639118654.5756518840789794921875;i:4;a:2:{i:0;a:5:{s:4:"file";s:60:"/home/onnviiod/public_html/alhuda/views/fee/students-fee.php";s:4:"line";i:274;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:63:"/home/onnviiod/public_html/alhuda/controllers/FeeController.php";s:4:"line";i:327;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:9081504;}i:288;a:6:{i:0;s:71:"SELECT COUNT(*) FROM `stu_reg_log_association` WHERE `fk_stu_id`='2415'";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1639118654.5760478973388671875;i:4;a:2:{i:0;a:5:{s:4:"file";s:60:"/home/onnviiod/public_html/alhuda/views/fee/students-fee.php";s:4:"line";i:285;s:8:"function";s:5:"count";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:63:"/home/onnviiod/public_html/alhuda/controllers/FeeController.php";s:4:"line";i:327;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:9084104;}i:291;a:6:{i:0;s:155:"SELECT COUNT(*) FROM `stu_reg_log_association` WHERE (`fk_stu_id`=2415) AND (date(promoted_date) >= '2021-03-31') AND (date(promoted_date) <= '2022-03-31')";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1639118654.5763080120086669921875;i:4;a:2:{i:0;a:5:{s:4:"file";s:60:"/home/onnviiod/public_html/alhuda/views/fee/students-fee.php";s:4:"line";i:287;s:8:"function";s:5:"count";s:5:"class";s:12:"yii\db\Query";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:63:"/home/onnviiod/public_html/alhuda/controllers/FeeController.php";s:4:"line";i:327;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:9092472;}i:294;a:6:{i:0;s:100:"Access to debugger is denied due to IP address restriction. The requesting IP address is 39.33.45.17";i:1;i:2;i:2;s:29:"yii\debug\Module::checkAccess";i:3;