AND rc.table_name = 'session' AND kcu.table_name = 'session'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612613389.18453502655029296875;i:4;a:0:{}i:5;i:1771504;}i:65;a:6:{i:0;s:615:"SELECT
