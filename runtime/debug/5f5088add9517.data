ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599113390.28347492218017578125;i:4;a:0:{}i:5;i:6973856;}i:49;a:6:{i:0;s:1977:"SELECT
