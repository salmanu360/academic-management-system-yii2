ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1692691417.56365203857421875;i:4;a:0:{}i:5;i:10767368;}i:418;a:6:{i:0;s:396:"SELECT
