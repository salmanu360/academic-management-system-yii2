    `information_schema`.`TABLE_CONSTRAINTS` AS `tc`
WHERE
    `kcu`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `kcu`.`TABLE_NAME` = 'session'
    AND `tc`.`TABLE_SCHEMA` = `kcu`.`TABLE_SCHEMA` AND `tc`.`TABLE_NAME` = 'session' AND `tc`.`CONSTRAINT_NAME` = `kcu`.`CONSTRAINT_NAME` AND `tc`.`CONSTRAINT_TYPE` IN ('PRIMARY KEY', 'UNIQUE')
ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1653967324.2140200138092041015625;i:4;a:0:{}i:5;i:6881616;}}}";s:2:"db";s:93057:"a:1:{s:8:"messages";a:147:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1653967314 AND `id`='fkq2ujh9spdh9320qr9porq3v3'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1653967314.5906670093536376953125;i:4;a:0:{}i:5;i:4441544;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1653967314 AND `id`='fkq2ujh9spdh9320qr9porq3v3'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1653967314.59218597412109375;i:4;a:0:{}i:5;i:4442448;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1653967314.7943189144134521484375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5217424;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1653967314.796061038970947265625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5240584;}i:15;a:6:{i:0;s:609:"SELECT
