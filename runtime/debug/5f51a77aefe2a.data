        kcu.constraint_catalog = rc.constraint_catalog OR
        (kcu.constraint_catalog IS NULL AND rc.constraint_catalog IS NULL)
    ) AND
    kcu.constraint_schema = rc.constraint_schema AND
    kcu.constraint_name = rc.constraint_name
WHERE rc.constraint_schema = database() AND kcu.table_schema = database()
AND rc.table_name = 'signature' AND kcu.table_name = 'signature'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599186812.6294100284576416015625;i:4;a:2:{i:0;a:5:{s:4:"file";s:76:"/home/onnviiod/public_html/alhuda/views/exams/_ajax/pdfs/student-dmc-pdf.php";s:4:"line";i:171;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:65:"/home/onnviiod/public_html/alhuda/controllers/ExamsController.php";s:4:"line";i:1777;s:8:"function";s:13:"renderPartial";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:8166080;}i:263;a:6:{i:0;s:619:"SELECT
