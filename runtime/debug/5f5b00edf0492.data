ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599799534.131372928619384765625;i:4;a:0:{}i:5;i:8969648;}i:246;a:6:{i:0;s:396:"SELECT
