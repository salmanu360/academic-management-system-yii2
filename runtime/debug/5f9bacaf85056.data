FROM `information_schema`.`STATISTICS` AS `s`
WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1604037813.5211780071258544921875;i:4;a:0:{}i:5;i:2452688;}i:202;a:6:{i:0;s:418:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;success|s:26:\"Fee Submitted Successfully\";', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1605247413) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1604037813.521378993988037109375;i:4;a:0:{}i:5;i:2453864;}i:203;a:6:{i:0;s:418:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;success|s:26:\"Fee Submitted Successfully\";', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1605247413) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1604037813.6505749225616455078125;i:4;a:0:{}i:5;i:2454248;}}}";s:2:"db";s:77585:"a:1:{s:8:"messages";a:122:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1604037807 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1604037807.5420920848846435546875;i:4;a:0:{}i:5;i:1470160;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1604037807 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1604037807.5423510074615478515625;i:4;a:0:{}i:5;i:1471040;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1604037807.5430290699005126953125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"