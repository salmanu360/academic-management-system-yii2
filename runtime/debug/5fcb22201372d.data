ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1607148064.497992992401123046875;i:4;a:0:{}i:5;i:3222584;}i:247;a:6:{i:0;s:396:"SELECT
