ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1687958100.2876150608062744140625;i:4;a:0:{}i:5;i:9181872;}i:145;a:6:{i:0;s:1977:"SELECT
