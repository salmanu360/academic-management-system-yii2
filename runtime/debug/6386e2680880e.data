ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1669784168.9501969814300537109375;i:4;a:0:{}i:5;i:24689776;}i:2982;a:6:{i:0;s:1977:"SELECT
