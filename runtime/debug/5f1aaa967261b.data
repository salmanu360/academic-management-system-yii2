ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1595583126.72533893585205078125;i:4;a:0:{}i:5;i:18103424;}i:135;a:6:{i:0;s:1977:"SELECT
