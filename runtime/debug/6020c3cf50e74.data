ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612760022.4016780853271484375;i:4;a:0:{}i:5;i:3748760;}i:742;a:6:{i:0;s:408:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:37:\"Student Attendance Successfully saved\";', 1573, 1, '5kqoqutiq40utv3r216uqvl115', 1613969622) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1612760022.4018840789794921875;i:4;a:0:{}i:5;i:3749936;}i:743;a:6:{i:0;s:408:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:37:\"Student Attendance Successfully saved\";', 1573, 1, '5kqoqutiq40utv3r216uqvl115', 1613969622) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1612760023.9815900325775146484375;i:4;a:0:{}i:5;i:3750320;}}}";s:2:"db";s:244380:"a:1:{s:8:"messages";a:482:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612760015 AND `id`='5kqoqutiq40utv3r216uqvl115'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612760015.3285648822784423828125;i:4;a:0:{}i:5;i:1513920;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612760015 AND `id`='5kqoqutiq40utv3r216uqvl115'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612760015.3287160396575927734375;i:4;a:0:{}i:5;i:1514768;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612760015.3293819427490234375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseAct