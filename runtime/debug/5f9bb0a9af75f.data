FROM `information_schema`.`STATISTICS` AS `s`
WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1604038830.006619930267333984375;i:4;a:0:{}i:5;i:2453520;}i:202;a:6:{i:0;s:418:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;success|s:26:\"Fee Submitted Successfully\";', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1605248429) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1604038830.0068759918212890625;i:4;a:0:{}i:5;i:2454696;}i:203;a:6:{i:0;s:418:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;success|s:26:\"Fee Submitted Successfully\";', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1605248429) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1604038830.0398418903350830078125;i:4;a:0:{}i:5;i:2455080;}}}";s:2:"db";s:77593:"a:1:{s:8:"messages";a:122:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1604038825 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1604038825.716042041778564453125;i:4;a:0:{}i:5;i:1470160;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1604038825 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1604038825.7162549495697021484375;i:4;a:0:{}i:5;i:1471040;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1604038825.716887950897216796875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class