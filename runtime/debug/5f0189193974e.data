ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1593936155.18175792694091796875;i:4;a:0:{}i:5;i:7097672;}i:43;a:6:{i:0;s:1977:"SELECT
