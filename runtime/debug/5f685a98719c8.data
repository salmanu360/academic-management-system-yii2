ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1600674456.93782901763916015625;i:4;a:0:{}i:5;i:12245360;}i:868;a:6:{i:0;s:396:"SELECT
