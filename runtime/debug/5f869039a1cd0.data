ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602654265.7693920135498046875;i:4;a:0:{}i:5;i:3234936;}i:137;a:6:{i:0;s:396:"SELECT
