ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1607666763.430365085601806640625;i:4;a:0:{}i:5;i:3222216;}i:247;a:6:{i:0;s:396:"SELECT
