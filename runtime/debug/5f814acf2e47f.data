FROM `information_schema`.`STATISTICS` AS `s`
WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602308815.3382580280303955078125;i:4;a:0:{}i:5;i:2214496;}i:148;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'a8biovtnjtiivia3dfjk51t9v1', 1603518415) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1602308815.3384349346160888671875;i:4;a:0:{}i:5;i:2215592;}i:149;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'a8biovtnjtiivia3dfjk51t9v1', 1603518415) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1602308815.3386089801788330078125;i:4;a:0:{}i:5;i:2215976;}}}";s:2:"db";s:53876:"a:1:{s:8:"messages";a:86:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1602308815 AND `id`='a8biovtnjtiivia3dfjk51t9v1'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1602308815.18369293212890625;i:4;a:0:{}i:5;i:1457880;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1602308815 AND `id`='a8biovtnjtiivia3dfjk51t9v1'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602308815.1838219165802001953125;i:4;a:0:{}i:5;i:1458728;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1602308815.184474945068359375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1606048;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602308