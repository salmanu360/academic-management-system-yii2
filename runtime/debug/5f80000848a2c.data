ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602224136.450623989105224609375;i:4;a:0:{}i:5;i:2214896;}i:94;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'k6qeaq9dsaoegkjic0a84r9kg3', 1603433736) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1602224136.45081996917724609375;i:4;a:0:{}i:5;i:2216072;}i:95;a:6:{i:0;s:405:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'k6qeaq9dsaoegkjic0a84r9kg3', 1603433736) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1602224136.4850749969482421875;i:4;a:0:{}i:5;i:2216456;}}}";s:2:"db";s:28170:"a:1:{s:8:"messages";a:50:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1602224136 AND `id`='k6qeaq9dsaoegkjic0a84r9kg3'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1602224136.2945730686187744140625;i:4;a:0:{}i:5;i:1465056;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1602224136 AND `id`='k6qeaq9dsaoegkjic0a84r9kg3'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602224136.29489898681640625;i:4;a:0:{}i:5;i:1465904;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1602224136.2955000400543212890625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s