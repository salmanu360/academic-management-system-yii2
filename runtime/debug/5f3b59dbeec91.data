ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1597725148.11637592315673828125;i:4;a:0:{}i:5;i:8812232;}i:217;a:6:{i:0;s:396:"SELECT
