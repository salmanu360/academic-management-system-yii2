ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1696325660.6266429424285888671875;i:4;a:0:{}i:5;i:9175216;}i:145;a:6:{i:0;s:1977:"SELECT
