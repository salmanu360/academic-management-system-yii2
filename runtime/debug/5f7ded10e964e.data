ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602088209.04337310791015625;i:4;a:0:{}i:5;i:1998488;}i:54;a:6:{i:0;s:396:"SELECT
    `s`.`INDEX_NAME` AS `name`,
