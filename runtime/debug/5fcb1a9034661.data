ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1607146128.3428161144256591796875;i:4;a:0:{}i:5;i:3471960;}i:294;a:6:{i:0;s:396:"SELECT
