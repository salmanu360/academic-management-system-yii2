ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1606893234.6067459583282470703125;i:4;a:0:{}i:5;i:3855896;}i:145;a:6:{i:0;s:1977:"SELECT
