ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1602486556.975985050201416015625;i:4;a:0:{}i:5;i:3220680;}i:246;a:6:{i:0;s:396:"SELECT
