FROM information_schema.referential_constraints AS rc
JOIN information_schema.key_column_usage AS kcu ON
    (
        kcu.constraint_catalog = rc.constraint_catalog OR
        (kcu.constraint_catalog IS NULL AND rc.constraint_catalog IS NULL)
    ) AND
    kcu.constraint_schema = rc.constraint_schema AND
    kcu.constraint_name = rc.constraint_name
WHERE rc.constraint_schema = database() AND kcu.table_schema = database()
AND rc.table_name = 'session' AND kcu.table_name = 'session'";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1601742297.61199188232421875;i:4;a:2:{i:0;a:5:{s:4:"file";s:61:"/home/onnviiod/public_html/alhuda/components/CommonHelper.php";s:4:"line";i:32;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:65:"/home/onnviiod/public_html/alhuda/controllers/ExamsController.php";s:4:"line";i:2333;s:8:"function";s:9:"getBranch";s:5:"class";s:27:"app\components\CommonHelper";s:4:"type";s:2:"::";}}i:5;i:2026784;}i:50;a:6:{i:0;s:368:"SELECT `student_info`.`stu_id`, `student_info`.`is_active`, `u`.`username` AS `roll_no`, `u`.`id` AS `user_id` FROM `student_info` INNER JOIN `user` `u` ON u.id=student_info.user_id WHERE (`student_info`.`fk_branch_id`=1) AND (`student_info`.`class_id`=15) AND (`student_info`.`group_id` IS NULL) AND (`student_info`.`section_id`=35) AND (`student_info`.`is_active`=1)";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1601742297.6124260425567626953125;i:4;a:1:{i:0;a:5:{s:4:"file";s:65:"/home/onnviiod/public_html/alhuda/controllers/ExamsController.php";s:4:"line";i:2335;s:8:"function";s:3:"all";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}}i:5;i:2031008;}i:53;a:6:{i:0;s:43:"SELECT * FROM `session` WHERE `user_id`=607";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1601742297.613028049468994140625;i:4;a:2:{i:0;a:5:{s:4:"file";s:61:"/home/onnviiod/public_html/alhuda/components/CommonHelper.php";s:4:"line";i:32;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:65:"/home/onnviiod/public_html/alhuda/controllers/ExamsController.php";s:4:"line";i:2350;s:8:"function";s:9:"getBranch";s:5:"class";s:27:"app\components\CommonHelper";s:4:"type";s:2:"::";}}i:5;i:2067536;}i:56;a:6:{i:0;s:766:"SELECT `st`.`stu_id`, `st`.`is_active`, concat(u.first_name," ",u.middle_name," ",u.last_name) student_name FROM `exam` INNER JOIN `exam_type` `et` ON et.id