    kcu.constraint_name,
    kcu.column_name,
    kcu.referenced_table_name,
    kcu.referenced_column_name
FROM information_schema.referential_constraints AS rc
JOIN information_schema.key_column_usage AS kcu ON
    (
        kcu.constraint_catalog = rc.constraint_catalog OR
        (kcu.constraint_catalog IS NULL AND rc.constraint_catalog IS NULL)
    ) AND
    kcu.constraint_schema = rc.constraint_schema AND
    kcu.constraint_name = rc.constraint_name
WHERE rc.constraint_schema = database() AND kcu.table_schema = database()
AND rc.table_name = 'stop' AND kcu.table_name = 'stop'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1595585697.961090087890625;i:4;a:2:{i:0;a:5:{s:4:"file";s:72:"/home/onnviiod/public_html/alhuda/views/reports/finance/students-fee.php";s:4:"line";i:66;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:67:"/home/onnviiod/public_html/alhuda/controllers/ReportsController.php";s:4:"line";i:1514;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:7917872;}i:146;a:6:{i:0;s:609:"SELECT
