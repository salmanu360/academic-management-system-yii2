ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1648381821.03528690338134765625;i:4;a:0:{}i:5;i:7902408;}i:158;a:6:{i:0;s:330:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:580;', 580, 1, 'c7e0urkbqcda03bhos1jhat3d2', 1649591417) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1648381821.035830974578857421875;i:4;a:0:{}i:5;i:7908032;}i:159;a:6:{i:0;s:330:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:580;', 580, 1, 'c7e0urkbqcda03bhos1jhat3d2', 1649591417) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1648381821.0362091064453125;i:4;a:0:{}i:5;i:7908472;}}}";s:2:"db";s:57171:"a:1:{s:8:"messages";a:88:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1648381816 AND `id`='c7e0urkbqcda03bhos1jhat3d2'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1648381817.0115430355072021484375;i:4;a:0:{}i:5;i:4448704;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1648381816 AND `id`='c7e0urkbqcda03bhos1jhat3d2'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1648381817.0119359493255615234375;i:4;a:0:{}i:5;i:4449608;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1648381817.04154491424560546875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5224584;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1648381817.04