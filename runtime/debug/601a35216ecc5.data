FROM `information_schema`.`STATISTICS` AS `s`
WHERE `s`.`TABLE_SCHEMA` = COALESCE(NULL, DATABASE()) AND `s`.`INDEX_SCHEMA` = `s`.`TABLE_SCHEMA` AND `s`.`TABLE_NAME` = 'session'
ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612330273.7114570140838623046875;i:4;a:0:{}i:5;i:2760480;}i:267;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '215hcvo8lq5p679b4dpsk9ug03', 1613539873) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1612330273.7117230892181396484375;i:4;a:0:{}i:5;i:2761576;}i:268;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, '215hcvo8lq5p679b4dpsk9ug03', 1613539873) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1612330273.845098972320556640625;i:4;a:0:{}i:5;i:2761960;}}}";s:2:"db";s:134688:"a:1:{s:8:"messages";a:164:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612330273 AND `id`='215hcvo8lq5p679b4dpsk9ug03'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612330273.3156940937042236328125;i:4;a:0:{}i:5;i:1457848;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1612330273 AND `id`='215hcvo8lq5p679b4dpsk9ug03'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612330273.4503419399261474609375;i:4;a:0:{}i:5;i:1458696;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612330273.45137500762939453125;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1606016;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d