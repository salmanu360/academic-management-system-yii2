ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599026552.3595669269561767578125;i:4;a:0:{}i:5;i:7438792;}i:94;a:6:{i:0;s:417:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:19:\"/alhuda/web/student\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'mfu10at3gbvdou64ke8fjtgnt4', 1600236152) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1599026552.3598229885101318359375;i:4;a:0:{}i:5;i:7445136;}i:95;a:6:{i:0;s:417:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:1:{s:7:\"success\";i:-1;}__returnUrl|s:19:\"/alhuda/web/student\";__id|i:1573;success|s:34:\"Oficial details successfully saved\";', 1573, 1, 'mfu10at3gbvdou64ke8fjtgnt4', 1600236152) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1599026552.6513669490814208984375;i:4;a:0:{}i:5;i:7445576;}}}";s:2:"db";s:28166:"a:1:{s:8:"messages";a:50:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599026551 AND `id`='mfu10at3gbvdou64ke8fjtgnt4'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599026551.836698055267333984375;i:4;a:0:{}i:5;i:4469040;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1599026551 AND `id`='mfu10at3gbvdou64ke8fjtgnt4'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1599026551.8369300365447998046875;i:4;a:0:{}i:5;i:4469960;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1599026551.8411710262298583984375;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class