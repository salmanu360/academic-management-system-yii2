ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1595584185.42012310028076171875;i:4;a:0:{}i:5;i:7527728;}i:141;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'd76bdnll4ap8lgod7lp2qq0ta2', 1596793785) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1595584185.420525074005126953125;i:4;a:0:{}i:5;i:7533992;}i:142;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'd76bdnll4ap8lgod7lp2qq0ta2', 1596793785) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1595584185.4209940433502197265625;i:4;a:0:{}i:5;i:7534432;}}}";s:2:"db";s:55921:"a:1:{s:8:"messages";a:80:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1595584182 AND `id`='d76bdnll4ap8lgod7lp2qq0ta2'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1595584182.7371079921722412109375;i:4;a:0:{}i:5;i:4461704;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1595584182 AND `id`='d76bdnll4ap8lgod7lp2qq0ta2'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1595584184.9087979793548583984375;i:4;a:0:{}i:5;i:4462608;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1595584184.9153959751129150390625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5241256;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1