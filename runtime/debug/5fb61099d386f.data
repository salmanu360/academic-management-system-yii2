ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1605767322.50292301177978515625;i:4;a:0:{}i:5;i:6870736;}i:1078;a:6:{i:0;s:396:"SELECT
