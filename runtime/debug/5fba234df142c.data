ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1606034254.1055328845977783203125;i:4;a:0:{}i:5;i:2938152;}i:193;a:6:{i:0;s:396:"SELECT
