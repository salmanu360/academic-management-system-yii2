ORDER BY `position` ASC";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1595584576.4120171070098876953125;i:4;a:0:{}i:5;i:21815120;}i:126;a:6:{i:0;s:1977:"SELECT
