ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601882109.8419630527496337890625;i:4;a:0:{}i:5;i:3329712;}i:267;a:6:{i:0;s:353:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1603091709) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1601882109.8421480655670166015625;i:4;a:0:{}i:5;i:3396376;}i:268;a:6:{i:0;s:353:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:28:\"/alhuda/web/exams/award-list\";__id|i:1571;', 1571, 1, '6bb97mp0t02e4dadm0kkujkrj5', 1603091709) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1601882109.913794994354248046875;i:4;a:0:{}i:5;i:3396760;}}}";s:2:"db";s:123972:"a:1:{s:8:"messages";a:164:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1601882109 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601882109.72766208648681640625;i:4;a:0:{}i:5;i:1457944;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1601882109 AND `id`='6bb97mp0t02e4dadm0kkujkrj5'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1601882109.727870941162109375;i:4;a:0:{}i:5;i:1458824;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1601882109.728485107421875;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:1606160;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:2