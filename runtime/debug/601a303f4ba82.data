;s:45:"SELECT * FROM `ref_class` WHERE `class_id`=14";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612329023.36830997467041015625;i:4;a:2:{i:0;a:5:{s:4:"file";s:92:"/home/onnviiod/public_html/alhuda/views/reports/statistics/leave-school-year-student-pdf.php";s:4:"line";i:50;s:8:"function";s:5:"__get";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:67:"/home/onnviiod/public_html/alhuda/controllers/ReportsController.php";s:4:"line";i:1375;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:4547248;}i:637;a:6:{i:0;s:49:"SELECT * FROM `ref_section` WHERE `section_id`=33";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1612329023.3684089183807373046875;i:4;a:2:{i:0;a:5:{s:4:"file";s:92:"/home/onnviiod/public_html/alhuda/views/reports/statistics/leave-school-year-student-pdf.php";s:4:"line";i:52;s:8:"function";s:5:"__get";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:67:"/home/onnviiod/public_html/alhuda/controllers/ReportsController.php";s:4:"line";i:1375;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:4552976;}i:638;a:6:{i:0;s:49:"SELECT * FROM `ref_section` WHERE `section_id`=33";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1612329023.368545055389404296875;i:4;a:2:{i:0;a:5:{s:4:"file";s:92:"/home/onnviiod/public_html/alhuda/views/reports/statistics/leave-school-year-student-pdf.php";s:4:"line";i:52;s:8:"function";s:5:"__get";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:67:"/home/onnviiod/public_html/alhuda/controllers/ReportsController.php";s:4:"line";i:1375;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:4556080;}i:650;a:6:{i:0;s:1977:"SELECT
    `kcu`.`CONSTRAINT_NAME` AS `name`,
    `kcu`.`COLUMN_NAME` AS `column_name`,
    `tc`.`CONSTRAINT_TYPE` AS `type`,
    CASE
        WHEN NULL IS NULL AND `kcu`.`REFERENCED_TABLE_SCHEMA` = DATABASE() THEN NULL
        ELSE `kcu`.`REFERENCED_TABLE_SCHEMA`
    END AS `foreign_table_schema`,
    `kcu`.`REFERENCED_TABLE_NAME` AS `foreign_table_name`,
    `kcu`.`REFERENCED_COLUMN_NAME` AS `foreign_column_name`,
    `rc`.`UPDATE_RULE` AS `on_update`,
    `rc`.`DELETE_RULE` AS `on_delete`,
    `kcu`.`ORDINAL_POSITION` AS `position`
FROM
    `information_schema`.`KEY_COLUMN_USAGE` AS `kcu`,
    `information_schema`.`REFERENTIAL_CONSTRAINTS` AS `rc`,
