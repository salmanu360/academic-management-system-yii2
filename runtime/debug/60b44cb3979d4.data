ORDER BY `s`.`SEQ_IN_INDEX` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1622428852.7842929363250732421875;i:4;a:0:{}i:5;i:24995712;}i:3074;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'qibf9tjrfa1eahgb7td96vong6', 1623638452) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:80;i:2;s:23:"yii\db\Command::execute";i:3;d:1622428852.784576892852783203125;i:4;a:0:{}i:5;i:25001336;}i:3075;a:6:{i:0;s:332:"INSERT INTO `session` (`data`, `user_id`, `fk_branch_id`, `id`, `expire`) VALUES ('__flash|a:0:{}__returnUrl|s:8:\"/alhuda/\";__id|i:1573;', 1573, 1, 'qibf9tjrfa1eahgb7td96vong6', 1623638452) ON DUPLICATE KEY UPDATE `data`=VALUES(`data`), `user_id`=VALUES(`user_id`), `fk_branch_id`=VALUES(`fk_branch_id`), `expire`=VALUES(`expire`)";i:1;i:96;i:2;s:23:"yii\db\Command::execute";i:3;d:1622428852.784924030303955078125;i:4;a:0:{}i:5;i:25001776;}}}";s:2:"db";s:1265950:"a:1:{s:8:"messages";a:2030:{i:8;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1622428851 AND `id`='qibf9tjrfa1eahgb7td96vong6'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1622428851.6144540309906005859375;i:4;a:0:{}i:5;i:4441816;}i:9;a:6:{i:0;s:92:"SELECT `data` FROM `session` WHERE `expire`>1622428851 AND `id`='qibf9tjrfa1eahgb7td96vong6'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1622428851.6147649288177490234375;i:4;a:0:{}i:5;i:4442720;}i:12;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1622428851.618586063385009765625;i:4;a:1:{i:0;a:5:{s:4:"file";s:49:"/home/onnviiod/public_html/alhuda/models/User.php";s:4:"line";i:148;s:8:"function";s:7:"findOne";s:5:"class";s:23:"yii\db\BaseActiveRecord";s:4:"type";s:2:"::";}}i:5;i:5217696;}i:13;a:6:{i:0;s:29:"SHOW FULL COLUMNS FROM `user`";i:1;i:96;i:2;s:21:"yii\db\Command::query