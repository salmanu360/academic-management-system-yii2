php";s:4:"line";i:3310;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:13799256;}i:3055;a:6:{i:0;s:87:"SELECT * FROM `student_attendance` WHERE (`fk_stu_id`='2282') AND (`date`='2021-06-30')";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1622428852.25860500335693359375;i:4;a:2:{i:0;a:5:{s:4:"file";s:69:"/home/onnviiod/public_html/alhuda/views/student/_ajax/date-report.php";s:4:"line";i:76;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:67:"/home/onnviiod/public_html/alhuda/controllers/StudentController.php";s:4:"line";i:3310;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:13802880;}i:3056;a:6:{i:0;s:87:"SELECT * FROM `student_attendance` WHERE (`fk_stu_id`='2282') AND (`date`='2021-06-30')";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1622428852.2587358951568603515625;i:4;a:2:{i:0;a:5:{s:4:"file";s:69:"/home/onnviiod/public_html/alhuda/views/student/_ajax/date-report.php";s:4:"line";i:76;s:8:"function";s:3:"one";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:67:"/home/onnviiod/public_html/alhuda/controllers/StudentController.php";s:4:"line";i:3310;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:13805600;}i:3068;a:6:{i:0;s:1977:"SELECT
    `kcu`.`CONSTRAINT_NAME` AS `name`,
    `kcu`.`COLUMN_NAME` AS `column_name`,
    `tc`.`CONSTRAINT_TYPE` AS `type`,
    CASE
        WHEN NULL IS NULL AND `kcu`.`REFERENCED_TABLE_SCHEMA` = DATABASE() THEN NULL
        ELSE `kcu`.`REFERENCED_TABLE_SCHEMA`
    END AS `foreign_table_schema`,
    `kcu`.`REFERENCED_TABLE_NAME` AS `foreign_table_name`,
    `kcu`.`REFERENCED_COLUMN_NAME` AS `foreign_column_name`,
    `rc`.`UPDATE_RULE` AS `on_update`,
    `rc`.`DELETE_RULE` AS `on_delete`,
    `kcu`.`ORDINAL_POSITION` AS `position`
FROM
    `information_schema`.`KEY_COLUMN_USAGE` AS `kcu`,
    `information_schema`.`REFERENTIAL_CONSTRAINTS` AS `rc`,
    `information_schema`.`TABLE_CONSTRAINTS` AS `tc`
WHERE
