WHERE rc.constraint_schema = database() AND kcu.table_schema = database()
AND rc.table_name = 'subjects' AND kcu.table_name = 'subjects'";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1684476153.638742923736572265625;i:4;a:2:{i:0;a:5:{s:4:"file";s:73:"/home/onnviiod/public_html/alhuda/views/analysis/get-section-analysis.php";s:4:"line";i:346;s:8:"function";s:6:"widget";s:5:"class";s:15:"yii\base\Widget";s:4:"type";s:2:"::";}i:1;a:5:{s:4:"file";s:68:"/home/onnviiod/public_html/alhuda/controllers/AnalysisController.php";s:4:"line";i:123;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:18222296;}i:2568;a:6:{i:0;s:1977:"SELECT
    `kcu`.`CONSTRAINT_NAME` AS `name`,
    `kcu`.`COLUMN_NAME` AS `column_name`,
    `tc`.`CONSTRAINT_TYPE` AS `type`,
    CASE
        WHEN NULL IS NULL AND `kcu`.`REFERENCED_TABLE_SCHEMA` = DATABASE() THEN NULL
        ELSE `kcu`.`REFERENCED_TABLE_SCHEMA`
    END AS `foreign_table_schema`,
    `kcu`.`REFERENCED_TABLE_NAME` AS `foreign_table_name`,
    `kcu`.`REFERENCED_COLUMN_NAME` AS `foreign_column_name`,
    `rc`.`UPDATE_RULE` AS `on_update`,
    `rc`.`DELETE_RULE` AS `on_delete`,
    `kcu`.`ORDINAL_POSITION` AS `position`
FROM
    `information_schema`.`KEY_COLUMN_USAGE` AS `kcu`,
