ivision` ON subject_division.fk_subject_id = subjects.id LEFT JOIN `ref_section` ON ref_section.class_id=subjects.fk_class_id WHERE (`subjects`.`fk_class_id`='1') AND (`subjects`.`fk_group_id` IS NULL) AND (`ref_section`.`section_id`='') AND (`subjects`.`fk_branch_id`=1)";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1684476153.6373860836029052734375;i:4;a:2:{i:0;a:5:{s:4:"file";s:73:"/home/onnviiod/public_html/alhuda/views/analysis/get-section-analysis.php";s:4:"line";i:346;s:8:"function";s:6:"widget";s:5:"class";s:15:"yii\base\Widget";s:4:"type";s:2:"::";}i:1;a:5:{s:4:"file";s:68:"/home/onnviiod/public_html/alhuda/controllers/AnalysisController.php";s:4:"line";i:123;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:18197760;}i:2559;a:6:{i:0;s:33:"SHOW FULL COLUMNS FROM `subjects`";i:1;i:4;i:2;s:21:"yii\db\Command::query";i:3;d:1684476153.6380159854888916015625;i:4;a:2:{i:0;a:5:{s:4:"file";s:73:"/home/onnviiod/public_html/alhuda/views/analysis/get-section-analysis.php";s:4:"line";i:346;s:8:"function";s:6:"widget";s:5:"class";s:15:"yii\base\Widget";s:4:"type";s:2:"::";}i:1;a:5:{s:4:"file";s:68:"/home/onnviiod/public_html/alhuda/controllers/AnalysisController.php";s:4:"line";i:123;s:8:"function";s:10:"renderAjax";s:5:"class";s:18:"yii\web\Controller";s:4:"type";s:2:"->";}}i:5;i:18200248;}i:2562;a:6:{i:0;s:617:"SELECT
    kcu.constraint_name,
    kcu.column_name,
    kcu.referenced_table_name,
    kcu.referenced_column_name
FROM information_schema.referential_constraints AS rc
JOIN information_schema.key_column_usage AS kcu ON
    (
        kcu.constraint_catalog = rc.constraint_catalog OR
        (kcu.constraint_catalog IS NULL AND rc.constraint_catalog IS NULL)
    ) AND
    kcu.constraint_schema = rc.constraint_schema AND
    kcu.constraint_name = rc.constraint_name
WHERE rc.constraint_schema = database() AND kcu.table_schema = database()
