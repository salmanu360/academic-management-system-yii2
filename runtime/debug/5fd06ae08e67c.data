ORDER BY `position` ASC";i:1;i:96;i:2;s:21:"yii\db\Command::query";i:3;d:1607494369.5940101146697998046875;i:4;a:0:{}i:5;i:2268720;}i:145;a:6:{i:0;s:396:"SELECT
